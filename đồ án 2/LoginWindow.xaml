<Window x:Class="WpfApp3.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập - Quản lý thư viện"
        Height="500"
        Width="400"
        Background="#F1F5F9"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="RoundTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style x:Key="RoundPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Border Background="White" CornerRadius="14" Margin="20">
            <StackPanel VerticalAlignment="Center" Margin="30">
                <!-- Logo/Title -->
                <TextBlock 
                    Text="📚 Thư Viện" 
                    FontSize="32" 
                    FontWeight="Bold" 
                    Foreground="#2563EB"
                    TextAlignment="Center"
                    Margin="0,0,0,10"/>
                
                <TextBlock 
                    Text="Hệ thống quản lý thư viện"
                    FontSize="14"
                    Foreground="#64748B"
                    TextAlignment="Center"
                    Margin="0,0,0,30"/>

                <!-- Username -->
                <TextBlock Text="Tên đăng nhập" FontSize="13" Foreground="#0F172A" Margin="0,0,0,6"/>
                <Border BorderThickness="1" BorderBrush="#E2E8F0" CornerRadius="6" Margin="0,0,0,16">
                    <TextBox x:Name="UsernameInput" 
                        Height="40" 
                        Padding="12,10" 
                        FontSize="14"
                        Background="White"
                        BorderThickness="0"/>
                </Border>

                <!-- Password -->
                <TextBlock Text="Mật khẩu" FontSize="13" Foreground="#0F172A" Margin="0,0,0,6"/>
                <Border BorderThickness="1" BorderBrush="#E2E8F0" CornerRadius="6" Margin="0,0,0,16">
                    <PasswordBox x:Name="PasswordInput" 
                        Height="40" 
                        Padding="12,10" 
                        FontSize="14"
                        Background="White"
                        BorderThickness="0"/>
                </Border>

                <!-- Error Message -->
                <TextBlock x:Name="ErrorMessage" 
                    Text="" 
                    FontSize="12" 
                    Foreground="#EF4444"
                    TextWrapping="Wrap"
                    Margin="0,0,0,12"/>

                <!-- Login Button -->
                <Border BorderThickness="0" CornerRadius="6" Background="#2563EB" Margin="0,0,0,12">
                    <Button x:Name="LoginButton"
                        Content="Đăng nhập"
                        Height="42"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="LoginButton_Click"/>
                </Border>

                <!-- Demo Credentials Hint -->
                <TextBlock 
                    Text="Demo: admin / admin123"
                    FontSize="11"
                    Foreground="#94A3B8"
                    TextAlignment="Center"
                    Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
