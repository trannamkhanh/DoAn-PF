<Window x:Class="WpfApp3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp3"
        mc:Ignorable="d"
        Title="Quản lý thư viện"
        Height="760"
        Width="1260"
        Background="#F1F5F9"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="SecondaryBrush" Color="#E2E8F0" />
        <SolidColorBrush x:Key="DangerBrush" Color="#EF4444" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A" />
        <SolidColorBrush x:Key="CardBrush" Color="White" />
        <SolidColorBrush x:Key="BorderBrushLight" Color="#E2E8F0" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B" />

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLight}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="SideMenuItemStyle" TargetType="Border">
            <Setter Property="Background" Value="#1E293B" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="SideMenuItemActiveStyle" TargetType="Border" BasedOn="{StaticResource SideMenuItemStyle}">
            <Setter Property="Background" Value="#2563EB" />
        </Style>

        <Style x:Key="SideMenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1E293B" />
            <Setter Property="Foreground" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="48" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left" Margin="2,0,0,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#334155" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SideMenuButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource SideMenuButtonStyle}">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinHeight" Value="36" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinHeight" Value="36" />
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinHeight" Value="36" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SecondaryBrush}" />
            <Setter Property="Foreground" Value="#1E293B" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}" />
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SuccessBrush}" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="ContentOnlyTabControlStyle" TargetType="TabControl" BasedOn="{StaticResource {x:Type TabControl}}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter ContentSource="SelectedContent" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="#EAF1FF" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryBrush}" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLight}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RowBackground" Value="White" />
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#EDF2F7" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="ColumnHeaderHeight" Value="42" />
            <Setter Property="RowHeight" Value="38" />
            <Setter Property="CanUserResizeRows" Value="False" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F1F5F9" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" CornerRadius="16" Padding="16" BorderThickness="0" Background="#0F172A">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="📚 Library CMS" FontSize="22" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="Admin Panel" Margin="0,4,0,0" Foreground="#93C5FD" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,24,0,0">
                    <Button Style="{StaticResource SideMenuButtonActiveStyle}" Content="🏠 Trang chủ" Click="SidebarHome_Click" />
                    <Button Style="{StaticResource SideMenuButtonStyle}" Content="📘 Quản lý sách" Click="SidebarBooks_Click" />
                    <Button Style="{StaticResource SideMenuButtonStyle}" Content="👥 Quản lý thành viên" Click="SidebarMembers_Click" />
                    <Button Style="{StaticResource SideMenuButtonStyle}" Content="🔄 Mượn / Trả sách" Click="SidebarLoans_Click" />
                    <Button Style="{StaticResource SideMenuButtonStyle}" Content="📊 Báo cáo" Click="SidebarReports_Click" />
                </StackPanel>

                <Border Grid.Row="2" Background="#1E293B" CornerRadius="12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Thư viện trung tâm" Foreground="White" FontWeight="SemiBold" />
                        <TextBlock Text="Trạng thái: Online" Margin="0,4,0,0" Foreground="#86EFAC" FontSize="12" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="16" Padding="16" BorderThickness="0" Margin="0,0,0,12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0F172A" Offset="0" />
                        <GradientStop Color="#1E3A8A" Offset="0.55" />
                        <GradientStop Color="#2563EB" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold" Foreground="White" />
                        <TextBlock Text="Quản lý sách, thành viên và nghiệp vụ mượn trả" Margin="0,6,0,0" Foreground="#DBEAFE" FontSize="13" />
                    </StackPanel>
                    <Border Grid.Column="1" Background="#1D4ED8" CornerRadius="20" Padding="16,8" VerticalAlignment="Center">
                        <TextBlock Text="Online" Foreground="White" FontWeight="SemiBold" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="14">
                <TabControl x:Name="MainTabControl" Style="{StaticResource ContentOnlyTabControlStyle}">
                <TabItem Header="Trang chủ">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="Tổng quan thư viện" Style="{StaticResource SectionTitleStyle}" />
                            <UniformGrid Columns="4" Margin="0,10,0,0">
                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Tổng sách" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock x:Name="TxtHomeTotalBooks" Text="0" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Tổng thành viên" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock x:Name="TxtHomeTotalMembers" Text="0" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Phiếu đang mượn" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock x:Name="TxtHomeBorrowing" Text="0" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Phiếu đã trả" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock x:Name="TxtHomeReturned" Text="0" FontSize="20" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="1.2*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Sách mới cập nhật" Style="{StaticResource SectionTitleStyle}" Margin="12,10,12,8" FontSize="15" />
                                    <DataGrid Grid.Row="1" x:Name="HomeBooksGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="ISBN" Binding="{Binding Isbn}" Width="120" />
                                            <DataGridTextColumn Header="Tiêu đề" Binding="{Binding Title}" Width="*" />
                                            <DataGridTextColumn Header="Tồn" Binding="{Binding AvailableQuantity}" Width="70" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Thành viên mới" Style="{StaticResource SectionTitleStyle}" Margin="12,10,12,8" FontSize="15" />
                                    <DataGrid Grid.Row="1" x:Name="HomeMembersGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Mã" Binding="{Binding MemberCode}" Width="90" />
                                            <DataGridTextColumn Header="Họ tên" Binding="{Binding FullName}" Width="*" />
                                            <DataGridTextColumn Header="Ngày tham gia" Binding="{Binding JoinDate}" Width="110" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="4" Style="{StaticResource CardBorderStyle}" Padding="0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Lịch mượn / trả gần đây" Style="{StaticResource SectionTitleStyle}" Margin="12,10,12,8" FontSize="15" />
                                    <DataGrid Grid.Row="1" x:Name="HomeLoansGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Sách" Binding="{Binding BookTitle}" Width="*" />
                                            <DataGridTextColumn Header="Thành viên" Binding="{Binding MemberName}" Width="130" />
                                            <DataGridTextColumn Header="Mượn" Binding="{Binding BorrowDate}" Width="95" />
                                            <DataGridTextColumn Header="Trả" Binding="{Binding ReturnDate}" Width="95" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="Sách">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Danh sách sách" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,10" />

                        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="0" Margin="0,0,0,12">
                            <DataGrid x:Name="BooksGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionChanged="BooksGrid_SelectionChanged"
                                      Margin="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding BookId}" Width="60" />
                                    <DataGridTextColumn Header="ISBN" Binding="{Binding Isbn}" Width="140" />
                                    <DataGridTextColumn Header="Tiêu đề" Binding="{Binding Title}" Width="2*" />
                                    <DataGridTextColumn Header="Tác giả" Binding="{Binding Author}" Width="1.5*" />
                                    <DataGridTextColumn Header="NXB" Binding="{Binding Publisher}" Width="1.3*" />
                                    <DataGridTextColumn Header="Năm" Binding="{Binding PublishYear}" Width="80" />
                                    <DataGridTextColumn Header="Thể loại" Binding="{Binding Genre}" Width="120" />
                                    <DataGridTextColumn Header="Số lượng" Binding="{Binding Quantity}" Width="90" />
                                    <DataGridTextColumn Header="Còn lại" Binding="{Binding AvailableQuantity}" Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,10">
                                    <StackPanel Margin="4">
                                        <TextBlock Text="ISBN" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtBookIsbn" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Tiêu đề" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtBookTitle" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Tác giả" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtBookAuthor" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="NXB" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtBookPublisher" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Năm" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtBookPublishYear" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Thể loại" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtBookGenre" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Số lượng" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtBookQuantity" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Còn lại" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtBookAvailable" />
                                    </StackPanel>
                                </UniformGrid>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Style="{StaticResource SuccessButtonStyle}" Content="Thêm" Width="90" Click="AddBook_Click" />
                                    <Button Style="{StaticResource PrimaryButtonStyle}" Content="Cập nhật" Width="95" Click="UpdateBook_Click" />
                                    <Button Style="{StaticResource DangerButtonStyle}" Content="Xóa" Width="90" Click="DeleteBook_Click" />
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Làm mới" Width="95" Click="RefreshBooks_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Thành viên">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Danh sách thành viên" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,10" />

                        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="0" Margin="0,0,0,12">
                            <DataGrid x:Name="MembersGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionChanged="MembersGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding MemberId}" Width="60" />
                                    <DataGridTextColumn Header="Mã TV" Binding="{Binding MemberCode}" Width="100" />
                                    <DataGridTextColumn Header="Họ tên" Binding="{Binding FullName}" Width="1.8*" />
                                    <DataGridTextColumn Header="Ngày sinh" Binding="{Binding DateOfBirth}" Width="120" />
                                    <DataGridTextColumn Header="Giới tính" Binding="{Binding Gender}" Width="100" />
                                    <DataGridTextColumn Header="Điện thoại" Binding="{Binding Phone}" Width="120" />
                                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.5*" />
                                    <DataGridTextColumn Header="Địa chỉ" Binding="{Binding Address}" Width="2*" />
                                    <DataGridCheckBoxColumn Header="Hoạt động" Binding="{Binding IsActive}" Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,10">
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Mã thành viên" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtMemberCode" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Họ tên" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtMemberFullName" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Ngày sinh" Style="{StaticResource FieldLabelStyle}" />
                                        <DatePicker x:Name="DpMemberDob" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Giới tính" Style="{StaticResource FieldLabelStyle}" />
                                        <ComboBox x:Name="CmbMemberGender">
                                            <ComboBoxItem Content="Nam" />
                                            <ComboBoxItem Content="Nữ" />
                                            <ComboBoxItem Content="Khác" />
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Điện thoại" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtMemberPhone" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Email" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtMemberEmail" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Địa chỉ" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtMemberAddress" />
                                    </StackPanel>
                                    <StackPanel Margin="4" VerticalAlignment="Bottom">
                                        <CheckBox x:Name="ChkMemberActive" Content="Đang hoạt động" IsChecked="True" />
                                    </StackPanel>
                                </UniformGrid>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Style="{StaticResource SuccessButtonStyle}" Content="Thêm" Width="90" Click="AddMember_Click" />
                                    <Button Style="{StaticResource PrimaryButtonStyle}" Content="Cập nhật" Width="95" Click="UpdateMember_Click" />
                                    <Button Style="{StaticResource DangerButtonStyle}" Content="Xóa" Width="90" Click="DeleteMember_Click" />
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Làm mới" Width="95" Click="RefreshMembers_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Mượn trả">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Danh sách phiếu mượn" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,10" />

                        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="0" Margin="0,0,0,12">
                            <DataGrid x:Name="LoansGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionChanged="LoansGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Mã mượn" Binding="{Binding LoanId}" Width="80" />
                                    <DataGridTextColumn Header="Sách" Binding="{Binding BookTitle}" Width="2*" />
                                    <DataGridTextColumn Header="Thành viên" Binding="{Binding MemberName}" Width="1.5*" />
                                    <DataGridTextColumn Header="Ngày mượn" Binding="{Binding BorrowDate}" Width="120" />
                                    <DataGridTextColumn Header="Hạn trả" Binding="{Binding DueDate}" Width="120" />
                                    <DataGridTextColumn Header="Ngày trả" Binding="{Binding ReturnDate}" Width="120" />
                                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="100" />
                                    <DataGridTextColumn Header="Phạt" Binding="{Binding FineAmount}" Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,10">
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Sách" Style="{StaticResource FieldLabelStyle}" />
                                        <ComboBox x:Name="CmbLoanBook" DisplayMemberPath="Title" SelectedValuePath="BookId" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Thành viên" Style="{StaticResource FieldLabelStyle}" />
                                        <ComboBox x:Name="CmbLoanMember" DisplayMemberPath="FullName" SelectedValuePath="MemberId" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Ngày mượn" Style="{StaticResource FieldLabelStyle}" />
                                        <DatePicker x:Name="DpLoanBorrowDate" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Hạn trả" Style="{StaticResource FieldLabelStyle}" />
                                        <DatePicker x:Name="DpLoanDueDate" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Ngày trả" Style="{StaticResource FieldLabelStyle}" />
                                        <DatePicker x:Name="DpLoanReturnDate" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Trạng thái" Style="{StaticResource FieldLabelStyle}" />
                                        <ComboBox x:Name="CmbLoanStatus">
                                            <ComboBoxItem Content="Borrowing" />
                                            <ComboBoxItem Content="Returned" />
                                            <ComboBoxItem Content="Overdue" />
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Tiền phạt" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtLoanFine" />
                                    </StackPanel>
                                </UniformGrid>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Style="{StaticResource SuccessButtonStyle}" Content="Tạo phiếu mượn" Width="125" Click="AddLoan_Click" />
                                    <Button Style="{StaticResource PrimaryButtonStyle}" Content="Cập nhật" Width="95" Click="UpdateLoan_Click" />
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Đánh dấu đã trả" Width="130" Click="MarkReturned_Click" />
                                    <Button Style="{StaticResource DangerButtonStyle}" Content="Xóa" Width="90" Click="DeleteLoan_Click" />
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Làm mới" Width="95" Click="RefreshLoans_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Báo cáo">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="Tổng quan báo cáo" Style="{StaticResource SectionTitleStyle}" />
                            <UniformGrid Columns="5" Margin="0,10,0,0">
                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Tổng sách" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock x:Name="TxtSummaryBooks" Text="0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Tổng thành viên" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock x:Name="TxtSummaryMembers" Text="0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Tổng lượt mượn" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock x:Name="TxtSummaryLoans" Text="0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Lượt quá hạn" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock x:Name="TxtSummaryOverdue" Text="0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource DangerBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Tổng tiền phạt" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock x:Name="TxtSummaryFine" Text="0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>

                        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="0" Margin="0,0,0,12">
                            <DataGrid x:Name="ReportsGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionChanged="ReportsGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding ReportId}" Width="60" />
                                    <DataGridTextColumn Header="Loại" Binding="{Binding ReportType}" Width="130" />
                                    <DataGridTextColumn Header="Tiêu đề" Binding="{Binding ReportTitle}" Width="2*" />
                                    <DataGridTextColumn Header="Ngày" Binding="{Binding ReportDate}" Width="110" />
                                    <DataGridTextColumn Header="Người tạo" Binding="{Binding CreatedBy}" Width="130" />
                                    <DataGridTextColumn Header="Sách" Binding="{Binding TotalBooks}" Width="80" />
                                    <DataGridTextColumn Header="Thành viên" Binding="{Binding TotalMembers}" Width="100" />
                                    <DataGridTextColumn Header="Mượn" Binding="{Binding TotalLoans}" Width="80" />
                                    <DataGridTextColumn Header="Quá hạn" Binding="{Binding OverdueLoans}" Width="90" />
                                    <DataGridTextColumn Header="Phạt" Binding="{Binding TotalFine}" Width="100" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,10">
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Loại báo cáo" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtReportType" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Tiêu đề" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtReportTitle" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Ngày báo cáo" Style="{StaticResource FieldLabelStyle}" />
                                        <DatePicker x:Name="DpReportDate" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Người tạo" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtReportCreatedBy" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Tổng sách" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtReportTotalBooks" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Tổng thành viên" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtReportTotalMembers" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Tổng mượn" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtReportTotalLoans" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Quá hạn" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtReportOverdueLoans" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Tổng phạt" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtReportTotalFine" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Nội dung" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtReportContent" Height="70" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Ghi chú" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="TxtReportNotes" Height="70" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
                                    </StackPanel>
                                </UniformGrid>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Style="{StaticResource PrimaryButtonStyle}" Content="Tạo nhanh" Width="110" Click="GenerateReport_Click" />
                                    <Button Style="{StaticResource SuccessButtonStyle}" Content="Thêm" Width="90" Click="AddReport_Click" />
                                    <Button Style="{StaticResource PrimaryButtonStyle}" Content="Cập nhật" Width="95" Click="UpdateReport_Click" />
                                    <Button Style="{StaticResource DangerButtonStyle}" Content="Xóa" Width="90" Click="DeleteReport_Click" />
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Làm mới" Width="95" Click="RefreshReports_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
            </Border>
        </Grid>
    </Grid>
</Window>
